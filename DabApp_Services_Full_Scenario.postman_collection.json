{
  "info": {
    "name": "DabApp Services — Full Scenario (Subscription → Payment → Services)",
    "description": "Complete flow: Login → Subscribe → Pay → Use all 5 services. Each folder = one service with ordered steps.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",              "value": "http://localhost:8000", "type": "string" },
    { "key": "token",                 "value": "",                      "type": "string" },
    { "key": "user_id",               "value": "",                      "type": "string" },
    { "key": "plan_id",               "value": "1",                     "type": "string" },
    { "key": "subscription_id",       "value": "",                      "type": "string" },
    { "key": "service_id",            "value": "",                      "type": "string" },
    { "key": "booking_id",            "value": "",                      "type": "string" },
    { "key": "instructor_id",         "value": "1",                     "type": "string" },
    { "key": "instructor_location_id","value": "1",                     "type": "string" },
    { "key": "session_booking_id",    "value": "",                      "type": "string" },
    { "key": "tow_booking_id",        "value": "",                      "type": "string" }
  ],
  "item": [

    {
      "name": "00 — Authentication",
      "item": [
        {
          "name": "00.1 Login with Phone",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.token) {",
                "  pm.collectionVariables.set('token', res.token);",
                "  console.log('✅ Token saved');",
                "}",
                "if (res.user && res.user.id) {",
                "  pm.collectionVariables.set('user_id', res.user.id);",
                "  console.log('✅ User ID saved:', res.user.id);",
                "}",
                "pm.test('Login successful', () => pm.response.to.have.status(200));",
                "pm.test('Token received', () => pm.expect(res.token).to.be.a('string'));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"+212600000001\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/login", "host": ["{{base_url}}"], "path": ["api", "login"] }
          }
        },
        {
          "name": "00.2 Login with Email",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.token) {",
                "  pm.collectionVariables.set('token', res.token);",
                "  console.log('✅ Token saved');",
                "}",
                "if (res.user && res.user.id) {",
                "  pm.collectionVariables.set('user_id', res.user.id);",
                "}",
                "pm.test('Login successful', () => pm.response.to.have.status(200));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"user@dabapp.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/login", "host": ["{{base_url}}"], "path": ["api", "login"] }
          }
        },
        {
          "name": "00.3 [ERROR] Login Wrong Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"+212600000001\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/login", "host": ["{{base_url}}"], "path": ["api", "login"] }
          }
        }
      ]
    },

    {
      "name": "01 — Subscription & Payment",
      "item": [
        {
          "name": "01.1 List Subscription Plans",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.data && res.data.length > 0) {",
                "  pm.collectionVariables.set('plan_id', res.data[0].id);",
                "  console.log('✅ First plan ID saved:', res.data[0].id);",
                "}",
                "pm.test('Plans retrieved', () => pm.response.to.have.status(200));",
                "pm.test('Has plans', () => pm.expect(res.data).to.be.an('array').and.not.empty);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/subscription-plans?billing_cycle=monthly",
              "host": ["{{base_url}}"],
              "path": ["api", "subscription-plans"],
              "query": [{ "key": "billing_cycle", "value": "monthly" }]
            }
          }
        },
        {
          "name": "01.2 Get Plan Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/subscription-plans/{{plan_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "subscription-plans", "{{plan_id}}"]
            }
          }
        },
        {
          "name": "01.3 Subscribe to Business Plan",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.data && res.data.subscription_id) {",
                "  pm.collectionVariables.set('subscription_id', res.data.subscription_id);",
                "  console.log('✅ Subscription ID saved:', res.data.subscription_id);",
                "}",
                "pm.test('Subscription initiated', () => pm.response.to.have.status(200));",
                "if (res.data && res.data.payment_url) {",
                "  console.log('💳 Payment URL:', res.data.payment_url);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan_id\": {{plan_id}},\n  \"billing_cycle\": \"monthly\",\n  \"business_name\": \"Elite Moto Services\",\n  \"business_name_ar\": \"خدمات موتو إيليت\",\n  \"description\": \"Professional motorcycle services in Riyadh\",\n  \"description_ar\": \"خدمات دراجات نارية احترافية في الرياض\",\n  \"phone\": \"+966501234567\",\n  \"email\": \"contact@elitemoto.com\",\n  \"address\": \"King Fahd Road, Riyadh\",\n  \"address_ar\": \"طريق الملك فهد، الرياض\",\n  \"city_id\": 1,\n  \"country_id\": 1,\n  \"latitude\": 24.7136,\n  \"longitude\": 46.6753,\n  \"service_category_ids\": [1, 2],\n  \"price_per_hour\": 150,\n  \"price_per_mission\": 200,\n  \"working_hours\": [\n    { \"day_of_week\": 0, \"is_open\": false },\n    { \"day_of_week\": 1, \"is_open\": true, \"open_time\": \"08:00\", \"close_time\": \"18:00\" },\n    { \"day_of_week\": 2, \"is_open\": true, \"open_time\": \"08:00\", \"close_time\": \"18:00\" },\n    { \"day_of_week\": 3, \"is_open\": true, \"open_time\": \"08:00\", \"close_time\": \"18:00\" },\n    { \"day_of_week\": 4, \"is_open\": true, \"open_time\": \"08:00\", \"close_time\": \"18:00\" },\n    { \"day_of_week\": 5, \"is_open\": true, \"open_time\": \"08:00\", \"close_time\": \"14:00\" },\n    { \"day_of_week\": 6, \"is_open\": false }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/api/subscriptions/subscribe", "host": ["{{base_url}}"], "path": ["api", "subscriptions", "subscribe"] }
          }
        },
        {
          "name": "01.4 My Subscription Status",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "pm.test('Subscription retrieved', () => pm.response.to.have.status(200));",
                "if (res.data && res.data.subscription) {",
                "  console.log('📋 Status:', res.data.subscription.status);",
                "  console.log('📅 Renews:', res.data.subscription.next_billing_date);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/my-subscription", "host": ["{{base_url}}"], "path": ["api", "my-subscription"] }
          }
        },
        {
          "name": "01.5 Cancel Subscription",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Service no longer needed at this time\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/subscriptions/cancel", "host": ["{{base_url}}"], "path": ["api", "subscriptions", "cancel"] }
          }
        }
      ]
    },

